filters:
  and:
    - file.folder == "Decisions"
    - file.ext != "base"
formulas:
  Status: |
    if (this.supersededBy.isEmpty() || this.supersededBy == null, "Approved", "Superseded")
views:
  - type: table
    name: Table
    order:
      - file.name
      - formula.Status
    columnSize:
      file.name: 293
